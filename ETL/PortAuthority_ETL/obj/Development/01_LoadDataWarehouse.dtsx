    <DTS:Executable
      DTS:refId="Package\DFT-Load Fact_Passenger_Departures"
      DTS:CreationName="Microsoft.Pipeline"
      DTS:Description="Data Flow Task"
      DTS:DTSID="{BC073753-D21F-4AFF-AAA2-59302C872EB9}"
      DTS:ExecutableType="Microsoft.Pipeline"
      DTS:LocaleID="-1"
      DTS:ObjectName="DFT-Load Fact_Passenger_Departures"
      DTS:TaskContact="Performs high-performance data extraction, transformation and loading;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1">
      <DTS:Variables />
      <DTS:ObjectData>
        <pipeline
          version="1">
          <components>
            <component
              refId="Package\DFT-Load Fact_Passenger_Departures\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 
    d.Date_Key,
    c.Carrier_Key,
    w.Weather_Key,
    cov.COVID_Key,
    e.Event_Key,
    st.Service_Type_Key,
    f.Bus_Departures,
    f.Passenger_Departures,
    f.Passengers_Per_Bus,
    f.Baseline_2019_Buses,
    f.Baseline_2019_Passengers,
    f.Bus_Recovery_Percent,
    f.Passenger_Recovery_Percent,
    f.Bus_WoW_Change,
    f.Passenger_WoW_Change,
    f.Bus_4wk_MA,
    f.Passenger_4wk_MA,
    f.Bus_12wk_MA,
    f.Passenger_12wk_MA
FROM dbo.FinalDataset f
INNER JOIN dim.Dim_Date d 
    ON d.Week_Date = TRY_CAST(f.Week_Date AS DATE)
INNER JOIN dim.Dim_Carrier c 
    ON c.Carrier_Name = f.Carrier_Name
LEFT JOIN dim.Dim_Weather w 
    ON ISNULL(w.Avg_Temp_F, -999) = ISNULL(f.Avg_Temp_F, -999)
    AND ISNULL(w.Precipitation_Inches, -999) = ISNULL(f.Precipitation_Inches, -999)
    AND w.Weather_Condition = ISNULL(f.Weather_Condition, 'Unknown')
LEFT JOIN dim.Dim_COVID_Status cov 
    ON cov.COVID_Period = f.COVID_Period
    AND cov.Days_Since_Pandemic_Start = f.Days_Since_Pandemic_Start
LEFT JOIN dim.Dim_Event e 
    ON e.Is_Holiday = CASE WHEN f.Is_Holiday = 'True' THEN 1 ELSE 0 END
    AND e.Is_Tourism_Peak = CASE WHEN f.Is_Tourism_Peak = 'True' THEN 1 ELSE 0 END
    AND e.NYC_Event = ISNULL(f.NYC_Event, 'None')
LEFT JOIN dim.Dim_Service_Type st 
    ON st.Service_Type = f.Service_Type
WHERE f.Week_Date IS NOT NULL
  AND f.Carrier_Name IS NOT NULL;</property>
