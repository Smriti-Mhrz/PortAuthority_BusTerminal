                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=17.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT DISTINCT
    ROW_NUMBER() OVER (
        ORDER BY Days_Since_Pandemic_Start
    ) AS COVID_Key,
    COVID_Period,
    Economic_Period,
    CASE WHEN Is_COVID_Period = 'True' THEN 1 ELSE 0 END AS Is_COVID_Period,
    CASE WHEN Is_High_Inflation = 'True' THEN 1 ELSE 0 END AS Is_High_Inflation,
    Days_Since_Pandemic_Start
FROM dbo.FinalDataset
WHERE COVID_Period IS NOT NULL;</property>
